{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stratum",
  "main": "worker.js",
  "compatibility_date": "2025-09-27",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "AIRPORT_CACHE",
      "id": "b90577476db348e78298c8b0ff8fd500"
    }
  ]
}
